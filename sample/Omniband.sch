        <library name="rcl" urn="urn:adsk.eagle:library:334">
          <description>&lt;b&gt;Resistors, Capacitors, Inductors&lt;/b&gt;&lt;p&gt;
            Based on the previous libraries:
            &lt;ul&gt;
            &lt;li&gt;r.lbr
            &lt;li&gt;cap.lbr
            &lt;li&gt;cap-fe.lbr
            &lt;li&gt;captant.lbr
            &lt;li&gt;polcap.lbr
            &lt;li&gt;ipc-smd.lbr
            &lt;/ul&gt;
